# Copy this file to .env on the VM. Do not commit the real .env file.

NODE_ENV=production
PORT=5001
TZ=Asia/Kolkata

# Public URL that recipients can reach. Use your domain with HTTPS when available.
# For the current rootless Docker deployment, the default public port is 8080.
TRACKING_BASE_URL=
FRONTEND_URL=

# Rootless-router host port. Use a free high port unless you configure a privileged/forwarded 80/443 listener.
ROUTER_PORT=8091

# MongoDB
MONGODB_URI=

# Google OAuth / Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=
